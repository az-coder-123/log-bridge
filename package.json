{
  "name": "log-bridge",
  "version": "1.0.0",
  "description": "Local log server for Flutter apps with auto-discovery via mDNS",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js"
  },
  "keywords": ["log", "flutter", "mdns", "express"],
  "type": "module",
  "license": "MIT",
  "dependencies": {
    "bonjour-service": "^1.3.0",
    "chalk": "^5.3.0",
    "cors": "^2.8.5",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}